{
  "name": "issues",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --hmr --configuration=development",
    "build": "ng build --configuration=production",
    "prebuild": "npm run generate:api",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "generate:api": "openapi-generator-cli generate -i ../../../target/openapi/openapi.yaml -g typescript-angular -o src/app/generated --additional-properties=ngVersion=20.1.3,providedInRoot=true,apiModulePrefix=Issues,basePath=,serviceSuffix=Api"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.1.3",
    "@angular/cdk": "^20.1.3",
    "@angular/common": "^20.1.3",
    "@angular/compiler": "^20.1.3",
    "@angular/core": "^20.1.3",
    "@angular/forms": "^20.1.3",
    "@angular/material": "^20.1.3",
    "@angular/platform-browser": "^20.1.3",
    "@angular/router": "^20.1.3",
    "@jsverse/transloco": "~8.4.0",
    "chart.js": "^4.5.0",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.1.3",
    "@angular/build": "^20.1.3",
    "@angular/cli": "^20.1.3",
    "@angular/compiler-cli": "^20.1.3",
    "@auth0/angular-jwt": "^5.2.0",
    "@openapitools/openapi-generator-cli": "^2.18.4",
    "@types/jasmine": "~5.1.8",
    "angular-eslint": "20.2.0",
    "eslint": "^9.33.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "karma-sonarqube-reporter": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.40.0"
  }
}
